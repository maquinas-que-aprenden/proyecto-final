services:
  mlflow:
    image: ghcr.io/mlflow/mlflow
    ports:
      - "5000:5000"
    environment:
      - MLFLOW_HTTP_SITES_TRUSTED=*
      - MLFLOW_HTTP_SITES_ALLOW_EVERYTHING=true
    volumes:
      - mlflow_data:/mlflow
    restart: unless-stopped
    command: >
      mlflow server 
      --host 0.0.0.0 
      --port 5000 
      --backend-store-uri sqlite:///mlflow/mlflow.db 
      --default-artifact-root s3://normabot/artifacts/
      --allowed-hosts "*"

volumes:
  mlflow_data: