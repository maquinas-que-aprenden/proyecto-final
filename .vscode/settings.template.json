// Plantilla de configuración personal de VS Code para NormaBot.
// Copia este archivo como settings.json y ajusta los valores a tu entorno local.
// El archivo settings.json está en .gitignore: NO lo subas al repositorio.
{
  // ── Intérprete Python ────────────────────────────────────────────────────────
  // Elige según tu gestor de entornos:
  //   Conda:  "C:\\Users\\<tu-usuario>\\anaconda3\\envs\\venv_proyecto\\python.exe"
  //   venv:   "${workspaceFolder}\\.venv\\Scripts\\python.exe"
  //   pyenv:  ruta absoluta o deja que el selector de VS Code lo detecte
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",

  // ── Rutas extra para el analizador (opcional) ────────────────────────────────
  // Normalmente no hace falta si el intérprete ya apunta al entorno correcto.
  // Si Pylance no encuentra paquetes, añade aquí la carpeta site-packages:
  //   "python.analysis.extraPaths": [
  //     "C:\\Users\\<tu-usuario>\\anaconda3\\envs\\venv_proyecto\\Lib\\site-packages"
  //   ],

  // ── Configuración compartida (ya incluida en el settings.json base) ──────────
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingModuleSource": "none"
  }
}
